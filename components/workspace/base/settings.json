{
    // NOTE: If making changes to this file, be sure to check the development mode
    // for Labspaces (this file is overridden in the content development Compose file).
    "remote.autoForwardPorts": false,
    "security.workspace.trust.enabled": false,
    "window.autoDetectColorScheme": true,
    "terminal.integrated.env.linux": {
        "PATH": "${env:PATH}"
    },
    "terminal.integrated.scrollback": 10000,

    // This setting ensures that when a user goes from one lab to another, they won't
    // have the same files opened in the new lab. Every lab starts from scratch.
    "workbench.editor.restoreEditors": false
}